# Salin file ini menjadi .env.local, lalu isi dengan API key Anda sendiri.
# Ambil key di: https://aistudio.google.com/apikey
#
# PERINGATAN: variabel berawalan VITE_ ikut ter-bundle ke JavaScript yang
# dikirim ke browser. Key ini aman untuk dev lokal, tapi akan terbaca publik
# jika situs di-deploy. Untuk produksi, pindahkan panggilan Gemini ke backend.
VITE_GEMINI_API_KEY=
